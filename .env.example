TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_BOT_TOKEN=

# Legacy aliases from the previous parser project are also supported:
# API_ID, API_HASH, BOT_TOKEN, TARGET_USER_ID.

# Optional: if omitted, send /start to your bot and it will subscribe that chat.
TELEGRAM_TARGET_CHAT_ID=

# Optional runtime tuning.
DATABASE_PATH=data/leads.sqlite3
USER_SESSION_PATH=sessions/freelancer_user
BOT_SESSION_PATH=sessions/freelancer_delivery_bot
CATCH_UP_LIMIT=25
SEND_CATCH_UP=true
LOG_LEVEL=INFO
