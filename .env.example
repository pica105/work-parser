# ─── Обязательные ─────────────────────────────
# Получить: https://my.telegram.org/apps
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Получить: https://t.me/BotFather → /newbot
TELEGRAM_BOT_TOKEN=

# Твой Telegram ID (узнай у @userinfobot)
# Без этого бот не запустится!
ADMIN_TELEGRAM_ID=

# ─── База данных (опционально) ────────────────
# DATABASE_PATH=data/leads.sqlite3

# ─── Сессии Telethon (опционально) ────────────
# USER_SESSION_PATH=sessions/freelancer_user
# BOT_SESSION_PATH=sessions/freelancer_delivery_bot

# ─── Настройки catch-up (опционально) ─────────
# CATCH_UP_LIMIT=25
# SEND_CATCH_UP=true

# ─── Логирование (опционально) ────────────────
# LOG_LEVEL=INFO

# ─── Kwork: автоотклики (опционально) ─────────
#
# CSRF_USER_TOKEN — обязательно для отправки откликов:
#   1. Зайди на kwork.ru → войди в аккаунт
#   2. F12 → вкладка Application
#   3. Слева выбери Cookies → https://kwork.ru
#   4. Найди "csrf_user_token" → скопируй ЗНАЧЕНИЕ (длинная строка)
# CSRF_USER_TOKEN=
#
# KWORK_RORSSQIHEK (только если ошибка авторизации):
#   В тех же Cookies найди "RORSSQIHEK" → скопируй значение.
# KWORK_RORSSQIHEK=

# ─── Kwork: критерии отбора проектов ──────────
# Через запятую. Проект проходит, если хотя бы одно слово/фраза найдена в названии или описании.
# KWORK_CRITERIA=backend,api,rest,server,telegram bot,бэкенд,апи,серверная,микросервис,тг бот

# ─── OpenRouter: генерация откликов (опционально) ──
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=openai/gpt-4o-mini
# AI_BASIC_URL=https://openrouter.ai/api/v1/chat/completions